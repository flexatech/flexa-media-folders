{
    "name": "flexa-media-folders",
    "private": true,
    "version": "1.0.1",
    "type": "module",
    "packageManager": "pnpm@9.12.0",
    "scripts": {
        "dev": "vite -c apps/admin/vite.config.ts",
        "build": "tsc -p apps/admin/tsconfig.json --noEmit && vite build -c apps/admin/vite.config.ts",
        "preview": "vite preview -c apps/admin/vite.config.ts",
        "type-check": "tsc -p apps/admin/tsconfig.json --noEmit",
        "lint": "eslint apps/admin/src --ext .ts,.tsx",
        "format": "prettier --write \"apps/**/*.{ts,tsx,css}\""
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^8.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@formkit/auto-animate": "^0.9.0",
        "@radix-ui/react-context-menu": "^2.2.2",
        "@radix-ui/react-dialog": "^1.1.2",
        "@radix-ui/react-dropdown-menu": "^2.1.2",
        "@radix-ui/react-label": "^2.1.0",
        "@radix-ui/react-popover": "^1.1.2",
        "@radix-ui/react-scroll-area": "^1.2.10",
        "@radix-ui/react-slot": "^1.1.0",
        "@radix-ui/react-tabs": "^1.1.1",
        "@radix-ui/react-toast": "^1.2.2",
        "@radix-ui/react-tooltip": "^1.1.4",
        "@tanstack/react-query": "^5.62.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-react": "^0.469.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "tailwind-merge": "^2.5.5",
        "tw-animate-css": "^1.4.0",
        "zustand": "^5.0.2"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "@types/react": "^18.3.12",
        "@types/react-dom": "^18.3.1",
        "@vitejs/plugin-react": "^4.3.4",
        "eslint": "^9.16.0",
        "prettier": "^3.4.2",
        "tailwindcss": "^4.0.0",
        "typescript": "^5.7.2",
        "vite": "^6.0.0"
    },
    "engines": {
        "node": ">=20",
        "pnpm": ">=9"
    }
}
